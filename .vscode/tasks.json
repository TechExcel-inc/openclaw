{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Deploy: production (build + SSH)",
      "type": "shell",
      "command": "bash scripts/deploy-remote-production.sh",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Deploy: production (SSH only, no local build)",
      "type": "shell",
      "command": "bash scripts/deploy-remote-production.sh",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "SKIP_LOCAL_BUILD": "1"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    }
  ]
}
